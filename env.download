
import React, { useState } from 'react';
import { useTodoContext } from '../features/todos/todoContext';
import { TodoList } from '../features/todos/TodoList';
import { TodoForm } from '../features/todos/TodoForm';
import { Button } from '../components/ui/Button';
import { Modal } from '../components/ui/Modal';
import { FILTERS } from '../constants/filters';
import { Plus, Search, SlidersHorizontal, X } from 'lucide-react';
import { useTranslation } from '../hooks/useTranslation';

const Todos: React.FC = () => {
  const { state, dispatch } = useTodoContext();
  const { t } = useTranslation();
  const [isModalOpen, setIsModalOpen] = useState(false);

  const filters = [
    { label: t('allTasks'), value: FILTERS.ALL },
    { label: t('active'), value: FILTERS.ACTIVE },
    { label: t('completed'), value: FILTERS.COMPLETED },
  ];

  const activeCategory = state.categories.find(c => c.id === state.categoryFilter);

  return (
    <div className="space-y-6">
      <header className="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <div className="flex items-center gap-2">
            <h1 className="text-3xl font-bold text-slate-800 dark:text-white">{t('myTasks')}</h1>
            {activeCategory && (
              <div 
                className="flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold text-white shadow-sm animate-in zoom-in duration-300"
                style={{ backgroundColor: activeCategory.color }}
              >
                {activeCategory.name}
                <button 
                  onClick={() => dispatch({ type: 'SET_CATEGORY_FILTER', payload: null })}
                  className="hover:bg-black/20 rounded-full p-0.5 transition-colors"
                >
                  <X size={12} strokeWidth={3} />
                </button>
              </div>
            )}
          </div>
          <p className="text-slate-500 dark:text-slate-400">Manage and organize your daily workflow.</p>
        </div>
        <Button onClick={() => setIsModalOpen(true)} className="flex items-center gap-2 shadow-md">
          <Plus size={18} />
          {t('createTask')}
        </Button>
      </header>

      <div className="flex flex-col md:flex-row items-center justify-between gap-4 py-4 border-y border-slate-200 dark:border-slate-800">
        <div className="flex items-center p-1 bg-slate-100 dark:bg-slate-900 rounded-lg w-full md:w-auto">
          {filters.map((f) => (
            <button
              key={f.value}
              onClick={() => dispatch({ type: 'SET_FILTER', payload: f.value })}
              className={`flex-1 md:flex-none px-4 py-1.5 text-sm font-medium rounded-md transition-all ${
                state.filter === f.value
                  ? 'bg-white dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 shadow-sm'
                  : 'text-slate-500 hover:text-slate-700 dark:hover:text-slate-300'
              }`}
            >
              {f.label}
            </button>
          ))}
        </div>

        <div className="flex items-center gap-3 w-full md:w-auto">
          <div className="relative flex-1 md:w-64">
            <Search size={16} className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400" />
            <input 
              type="text" 
              placeholder={t('searchPlaceholder')}
              className="w-full pl-10 pr-4 py-2 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg text-sm outline-none focus:ring-2 focus:ring-indigo-500 dark:text-slate-200"
            />
          </div>
          <Button variant="outline" size="md" className="shrink-0">
            <SlidersHorizontal size={16} className="mr-2" />
            Filter
          </Button>
        </div>
      </div>

      <div className="max-w-4xl">
        <TodoList />
      </div>

      <Modal isOpen={isModalOpen} onClose={() => setIsModalOpen(false)} title={t('createTask')}>
        <TodoForm onSuccess={() => setIsModalOpen(false)} />
      </Modal>
    </div>
  );
};

export default Todos;
